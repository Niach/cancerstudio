# Local-only overrides belong in `.env`, which stays ignored.
# Keep repo-tracked config free of machine-specific absolute paths.

# ----------------------------------------------------------------------------
# Data root — mounted into the backend container as /app-data.
# Contains app.db, workspaces/, references/, inbox/.
# Default (if unset): ./data
# ----------------------------------------------------------------------------
# MUTAVAX_DATA_ROOT=/home/you/mutavax-data

# ----------------------------------------------------------------------------
# Host-mode dev: `next dev` on the host against the dockerized backend.
# SSR fetches in Next.js go through this URL; the browser uses the
# same-origin /backend/* rewrite. Leave unset inside the combined image.
# ----------------------------------------------------------------------------
# INTERNAL_API_URL=http://localhost:8000

# ----------------------------------------------------------------------------
# Public site mode — keeps `/` on the marketing hero instead of redirecting
# to /workspaces. Set on the mutavax.straehhuber.com Vercel build, not locally.
# ----------------------------------------------------------------------------
# MUTAVAX_MODE=public

# ----------------------------------------------------------------------------
# MHC binding predictor — defaults to MHCflurry (license-free). Set to
# NetMHCpan to use the DTU tools, which must live under MUTAVAX_NETMHC_DIR.
# ----------------------------------------------------------------------------
# MUTAVAX_CLASS_I_PREDICTOR=NetMHCpan

# DTU NetMHCpan / NetMHCIIpan install dir. Expected to contain
# netMHCpan-4.2/ and netMHCIIpan-4.3/ as shipped by DTU (no NMHOME edits).
# Bind-mounted at /tools/src:ro — matches the stock wrappers' hardcoded paths.
# Default (if unset): ${MUTAVAX_DATA_ROOT}/netmhc
# MUTAVAX_NETMHC_DIR=/home/you/dtu-netmhc

# ----------------------------------------------------------------------------
# Stage 9 — AI Review (LiteLLM). Pick any provider/model LiteLLM supports and
# set the matching key. LiteLLM resolves the key by model prefix.
# ----------------------------------------------------------------------------
# MUTAVAX_REVIEW_MODEL=anthropic/claude-opus-4-7
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GEMINI_API_KEY=
