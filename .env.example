# Local-only overrides belong in `.env`, which stays ignored.
# Keep repo-tracked config free of machine-specific absolute paths.

# ----------------------------------------------------------------------------
# Docker Compose: host-side data root
# ----------------------------------------------------------------------------
# Directory that gets mounted into the backend container as /app-data.
# Contains app.db, workspaces/, references/, inbox/, vep-cache/.
# Default (if unset): ~/cancerstudio-data
# CANCERSTUDIO_DATA_ROOT=/home/you/cancerstudio-data

# ----------------------------------------------------------------------------
# Native uvicorn dev (running the backend outside Docker)
# ----------------------------------------------------------------------------
# In-container path is hardcoded to /app-data in docker-compose.yml; this
# variable only applies when you run `uvicorn app.main:app` natively.
CANCERSTUDIO_APP_DATA_DIR=./data/app-data

# Optional SQLite override used only when DATABASE_URL is unset.
# Relative paths are resolved from the repository root.
# LOCAL_SQLITE_PATH=./data/app-data/app.db

# Optional test override for the real-data smoke FASTQs.
# REAL_DATA_SAMPLE_DIR=./data/sample-data/colo829-wgs/smoke

# Optional test override for the BAM/CRAM smoke fixtures.
# REAL_DATA_ALIGNMENT_SAMPLE_DIR=./data/sample-data/htslib-xx-pair/smoke

# Required when CRAM normalization needs a local reference.
# SAMTOOLS_REFERENCE_FASTA=./data/sample-data/htslib-xx-pair/smoke/xx.fa

# Optional local reference root and explicit FASTA overrides.
# If unset, cancerstudio stores downloaded presets under the app-data root.
# REFERENCE_BUNDLE_ROOT=./data/app-data/references
# REFERENCE_GRCH38_FASTA=./some/other/path/grch38.fa
# REFERENCE_CANFAM4_FASTA=./some/other/path/canfam4.fa
# REFERENCE_FELCAT9_FASTA=./some/other/path/felcat9.fa

# Optional aligner override. Default is the `strobealign` binary on PATH.
# ALIGNMENT_STROBEALIGN_BINARY=strobealign

# ----------------------------------------------------------------------------
# MHC binding predictors (DTU, externally licensed)
# ----------------------------------------------------------------------------
# Host dir containing the extracted DTU tarballs (netMHCpan-4.2/ and
# netMHCIIpan-4.3/ subdirectories, as shipped — no NMHOME edits needed).
# Bind-mounted at /tools/src:ro inside the backend container so the stock
# wrapper scripts' hardcoded NMHOME paths resolve cleanly.
# Default (if unset): ${CANCERSTUDIO_DATA_ROOT}/netmhc
# CANCERSTUDIO_NETMHC_DIR=/home/you/dtu-netmhc
